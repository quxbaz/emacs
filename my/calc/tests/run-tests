#!/usr/bin/env bash
# Run all ERT test suites under my/calc/tests/ in batch mode.
#
# Usage: ./run-tests
#
# test-init.el is loaded first to initialize packages (dash, s) that
# the source files depend on. Each other .el file is then loaded and
# run independently via ert-run-tests-batch-and-exit.
set -euo pipefail

EMACS_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
TESTS_DIR="$(dirname "$0")"

for f in "$TESTS_DIR"/*.el; do
  [[ "$f" == *test-init* ]] && continue
  echo "=== $(basename "$f") ==="
  emacs --batch -Q \
    --eval "(setq user-emacs-directory \"$EMACS_DIR/\")" \
    -l "$TESTS_DIR/test-init.el" \
    -l "$f" \
    -f ert-run-tests-batch-and-exit 2>&1 | grep -E "passed|FAILED|Ran [0-9]" | tail -3
done
