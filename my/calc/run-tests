#!/usr/bin/env bash
# Run all ERT test suites under my/calc/tests/ in batch mode.
#
# Usage: ./run-tests
#
# test-init.el is loaded first to initialize packages (dash, s) that
# the source files depend on. Each other .el file is then loaded and
# run independently via ert-run-tests-batch-and-exit.
set -euo pipefail

EMACS_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
TESTS_DIR="$(dirname "$0")/tests"

for f in "$TESTS_DIR"/*.el; do
  [[ "$f" == *test-init* ]] && continue
  name="$(basename "$f")"
  output=$(emacs --batch -Q \
    --eval "(setq user-emacs-directory \"$EMACS_DIR/\")" \
    -l "$TESTS_DIR/test-init.el" \
    -l "$f" \
    -f ert-run-tests-batch-and-exit 2>&1 || true)
  summary=$(echo "$output" | grep "Ran [0-9]")
  total=$(echo "$summary" | grep -o "Ran [0-9]*" | awk '{print $2}')
  unexpected=$(echo "$summary" | grep -o "[0-9]* unexpected" | awk '{print $1}')
  passed=$(( total - unexpected ))
  if [[ "$unexpected" == "0" ]]; then
    label="\033[32m[$passed/$total PASSED]\033[0m"
  else
    label="\033[31m[$passed/$total PASSED]\033[0m"
  fi
  echo -e "$label $name"
  echo "$summary"
  if [[ "$unexpected" != "0" ]]; then
    echo "$output" | grep "^   FAILED" | grep -v "[0-9]/[0-9]" | sed $'s/.*FAILED  /\033[31m•\033[0m \033[31mFAILED\033[0m /'
  fi
  echo
done
