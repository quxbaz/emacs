#!/usr/bin/env bash
# Run all ERT test suites under my/calc/tests/ in batch mode.
#
# Usage: ./run-tests [FILE]
#
# With no argument, runs every .el file under tests/.
# With FILE (e.g. my-math-ref-angle-tests.el), runs only that suite.
#
# test-init.el is loaded first to initialize packages (dash, s) that
# the source files depend on. Each other .el file is then loaded and
# run independently via ert-run-tests-batch-and-exit.
set -euo pipefail

EMACS_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
TESTS_DIR="$(dirname "$0")/tests"

if [[ $# -gt 0 ]]; then
  files=("$TESTS_DIR/$(basename "$1")")
else
  files=("$TESTS_DIR"/*.el)
fi

grand_total=0
grand_passed=0

for f in "${files[@]}"; do
  [[ "$f" == *test-init* ]] && continue
  name="$(basename "$f")"
  output=$(emacs --batch -Q \
    --eval "(setq user-emacs-directory \"$EMACS_DIR/\")" \
    -l "$TESTS_DIR/test-init.el" \
    -l "$f" \
    -f ert-run-tests-batch-and-exit 2>&1 || true)
  summary=$(echo "$output" | grep "Ran [0-9]")
  total=$(echo "$summary" | grep -o "Ran [0-9]*" | awk '{print $2}')
  unexpected=$(echo "$summary" | grep -o "[0-9]* unexpected" | awk '{print $1}')
  passed=$(( total - unexpected ))
  grand_total=$(( grand_total + total ))
  grand_passed=$(( grand_passed + passed ))
  if [[ "$unexpected" == "0" ]]; then
    label="\033[32m[$passed/$total PASSED]\033[0m"
  else
    label="\033[31m[$passed/$total PASSED]\033[0m"
  fi
  echo -e "$label $name"
  echo "$summary"
  if [[ "$unexpected" != "0" ]]; then
    echo "$output" | grep "^   FAILED" | grep -v "[0-9]/[0-9]" | sed $'s/.*FAILED  /\033[31m•\033[0m \033[31mFAILED\033[0m /'
  fi
  echo
done

RED="\033[31m"
GREEN="\033[32m"
RESET="\033[0m"

grand_failed=$(( grand_total - grand_passed ))
if [[ "$grand_passed" == "$grand_total" ]]; then
  line="$grand_passed/$grand_total TESTS PASSED"
  inner=$(( ${#line} + 2 ))
  hrule=$(printf '─%.0s' $(seq 1 $inner))
  echo -e "${GREEN}┌${hrule}┐${RESET}"
  echo -e "${GREEN}│ ${line} │${RESET}"
  echo -e "${GREEN}└${hrule}┘${RESET}"
else
  line_passed="$grand_passed/$grand_total TESTS PASSED"
  line_failed="$grand_failed/$grand_total TESTS FAILED"
  len=$(( ${#line_passed} > ${#line_failed} ? ${#line_passed} : ${#line_failed} ))
  inner=$(( len + 2 ))
  hrule=$(printf '─%.0s' $(seq 1 $inner))
  echo -e "${RED}┌${hrule}┐${RESET}"
  printf "${RED}│${RESET} ${GREEN}%-${len}s${RESET} ${RED}│${RESET}\n" "$line_passed"
  printf "${RED}│ %-${len}s │${RESET}\n" "$line_failed"
  echo -e "${RED}└${hrule}┘${RESET}"
fi
